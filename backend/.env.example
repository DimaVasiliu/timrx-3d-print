# TimrX 3D backend example environment
# Copy to .env for local development. Do not commit real secrets.

# Core backend
FLASK_ENV=development
PORT=5001
# Production uses timrx_admin (DML-only, no DDL).
# postgres is reserved for migrations and admin scripts.
DATABASE_URL=postgresql://timrx_admin:pass@localhost:5432/timrx
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Admin auth
ADMIN_TOKEN=replace-with-your-admin-token
# ADMIN_EMAILS=owner@example.com,admin@example.com

# Required to use Meshy generation
MESHY_API_KEY=replace-with-your-meshy-key

# Optional AI/image providers
OPENAI_API_KEY=replace-with-your-openai-key
GEMINI_API_KEY=
PIAPI_API_KEY=

# Optional video provider configuration
VIDEO_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
VERTEX_LOCATION=us-central1

# Optional payments
PAYMENTS_PROVIDER=mollie
MOLLIE_API_KEY=
MOLLIE_PROFILE_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_BASE_URL=http://localhost:5001
FRONTEND_BASE_URL=http://localhost:5500

# Optional email / magic code delivery
EMAIL_ENABLED=false
EMAIL_PROVIDER=ses
SES_FROM_EMAIL=
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional storage / uploads
AWS_BUCKET_MODELS=

# Optional webhooks
MESHY_WEBHOOK_ENABLED=false
MESHY_WEBHOOK_SECRET=
PIAPI_WEBHOOK_ENABLED=false
PIAPI_WEBHOOK_SECRET=
